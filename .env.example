# ============================================================
#  WhatsApp + Salesforce POC — Variáveis de Ambiente
# ============================================================

# --- Servidor local ---
PORT=3000
NODE_ENV=development

# --- Salesforce Connected App ---
# Obtenha em: Setup > App Manager > New Connected App
SF_LOGIN_URL=https://login.salesforce.com      # ou https://test.salesforce.com para sandbox
SF_CLIENT_ID=your_consumer_key_here
SF_CLIENT_SECRET=your_consumer_secret_here
SF_USERNAME=seu_usuario@empresa.com
SF_PASSWORD=sua_senha_aqui
SF_TOKEN=seu_security_token_aqui               # Reset em: My Settings > Personal > Reset My Security Token

# --- Comportamento da integração ---
# Número no formato internacional sem + e sem traços: 5534999998888
WA_ALLOWED_NUMBERS=                            # Deixe vazio para aceitar todos, ou separe por vírgula
WA_PREFIX_TRIGGER=!sf                          # Mensagens começando com isso viram Case no SF

# --- Webhook (opcional) para receber eventos externos ---
WEBHOOK_SECRET=troque_por_uma_chave_secreta_aleatoria

# --- Debug: desabilita integração com Salesforce (apenas WhatsApp) ---
SF_DISABLED=true
